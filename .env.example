# ================================================================
# .env.example — 이 파일을 복사해서 .env로 만들고 값을 채워주세요
# cp .env.example .env
# ================================================================

# ── 기상청 API 키 ──────────────────────────────────────────────────
# https://www.data.go.kr → 기상청 단기예보 API 신청
KMA_API_KEY=여기에_기상청_API_키_입력

# ── Claude (Anthropic) API 키 ─────────────────────────────────────
# https://console.anthropic.com
CLAUDE_API_KEY=여기에_Claude_API_키_입력

# ── PostgreSQL DB 설정 (Docker 환경) ──────────────────────────────
POSTGRES_DB=codi
POSTGRES_USER=codi_user
POSTGRES_PASSWORD=여기에_강한_비밀번호_입력

# db.py가 자동으로 읽는 연결 문자열 (docker-compose가 자동 주입)
# 로컬에서 Docker 없이 실행 시 주석 처리 → SQLite 자동 사용
DATABASE_URL=postgresql://codi_user:여기에_강한_비밀번호_입력@db:5432/codi

# ── Flask 설정 ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=여기에_랜덤_시크릿_키_입력
