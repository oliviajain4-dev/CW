# ================================================================
# .env.example — 이 파일을 복사해서 .env로 만들고 값을 채워주세요
# cp .env.example .env
# ================================================================

# ── 기상청 API 키 ──────────────────────────────────────────────────
# https://www.data.go.kr → 기상청 단기예보 API 신청
KMA_API_KEY=여기에_기상청_API_키_입력

# ── Claude (Anthropic) API 키 ─────────────────────────────────────
# https://console.anthropic.com
CLAUDE_API_KEY=여기에_Claude_API_키_입력

# ── PostgreSQL DB 설정 (Docker 환경) ──────────────────────────────
POSTGRES_DB=codi
POSTGRES_USER=codi_user
POSTGRES_PASSWORD=여기에_강한_비밀번호_입력

# db.py가 자동으로 읽는 연결 문자열 (docker-compose가 자동 주입)
# 로컬에서 Docker 없이 실행 시 주석 처리 → SQLite 자동 사용
DATABASE_URL=postgresql://codi_user:여기에_강한_비밀번호_입력@db:5432/codi

# ── Flask 설정 ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=여기에_랜덤_시크릿_키_입력

# ── Cloudinary (이미지 클라우드 저장) ────────────────────────────
CLOUDINARY_CLOUD_NAME=여기에_Cloud_Name
CLOUDINARY_API_KEY=여기에_API_Key
CLOUDINARY_API_SECRET=여기에_API_Secret

# ── Google Cloud Text-to-Speech ───────────────────────────────────
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → API 키 생성
# Text-to-Speech API 활성화 필요
GOOGLE_TTS_API_KEY=여기에_Google_TTS_API_Key

# ── Google OAuth (구글 로그인 + 캘린더 연동) ──────────────────────
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
# 미입력 시 구글 로그인 버튼/캘린더 TPO 기능이 비활성화됩니다 (앱은 정상 구동).
GOOGLE_CLIENT_ID=여기에_Google_OAuth_Client_ID
GOOGLE_CLIENT_SECRET=여기에_Google_OAuth_Client_Secret

# ── 세션 쿠키 이름 (선택, 기본값 session_local) ───────────────────
SESSION_COOKIE_NAME=session_docker

# ── (선택) Docker 없이 로컬 PostgreSQL에 직접 붙을 때 ─────────────
# 위 DATABASE_URL을 주석 처리하고, POSTGRES_USER/PASSWORD/DB와 함께 아래를 설정하면
# db.py가 자동으로 연결 문자열을 조립합니다. 미설정 시 SQLite로 폴백합니다.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
